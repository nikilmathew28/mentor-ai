  margin:20px 0;
  animation:cardIn 0.4s ease;
}
.diagnosis-card.visible{display:block}
.diagnosis-card.correct{
  background:linear-gradient(135deg,rgba(29,185,84,0.08),rgba(29,185,84,0.04));
  border:1px solid rgba(29,185,84,0.2);
}
.diagnosis-card.wrong{
  background:linear-gradient(135deg,rgba(255,77,28,0.06),rgba(123,47,255,0.04));
  border:1px solid rgba(255,77,28,0.15);
}
.diag-header{
  display:flex;align-items:center;gap:12px;
  margin-bottom:14px;
}
.diag-icon{font-size:1.8rem}
.diag-title{
