}
.btn-outline:hover{border-color:var(--ink);background:rgba(10,10,15,0.03)}

.btn-full{width:100%}
.action-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px}
.action-row.single{grid-template-columns:1fr}

/* ── Achievements ── */
