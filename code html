<script>
// ══════════════════════════════════════════════
// AGENTIC AI LEARNING MENTOR — FRONTEND ENGINE
// ══════════════════════════════════════════════

const API = 'http://localhost:5000';
const userId = 'user_' + Date.now() + '_' + Math.random().toString(36).substr(2,9);

let state = {
  lesson: null,
  questions: [],
  answers: [],
  submitted: false,
  hintLevels: {},
  userStats: { level:1, xp:0, streak:0, accuracy:0, companion:'🥚', weakSpots:{}, achievements:[] },
  progress: { current:1, total:0, percentage:0, completedLessons:0 }
};

// ── Custom Cursor ──
const $cursor = document.getElementById('cursor');
const $ring   = document.getElementById('cursor-ring');
let mx=0, my=0, rx=0, ry=0;
document.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; $cursor.style.left=mx+'px'; $cursor.style.top=my+'px'; });
(function animRing(){
  rx+=(mx-rx)*0.12; ry+=(my-ry)*0.12;
  $ring.style.left=rx+'px'; $ring.style.top=ry+'px';
  requestAnimationFrame(animRing);
})();
document.addEventListener('mousedown',()=>{ $cursor.style.width='8px'; $cursor.style.height='8px'; });
document.addEventListener('mouseup',()=>{ $cursor.style.width='12px'; $cursor.style.height='12px'; });

// ── Utilities ──
const $ = id => document.getElementById(id);
const show = id => $(id).style.display = '';
const hide = id => $(id).style.display = 'none';
const addClass = (id,cls) => $(id).classList.add(cls);
const removeClass = (id,cls) => $(id).classList.remove(cls);

function toast(msg, type='info', dur=4000){
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  const icons = {success:'✅',error:'❌',info:'ℹ️',warning:'⚠️'};
  el.innerHTML = `<span>${icons[type]||'📌'}</span> ${msg}`;
  $('toasts').appendChild(el);
  setTimeout(()=>{
    el.style.animation='toastOut 0.4s ease forwards';
    setTimeout(()=>el.remove(), 400);
  }, dur);
}

function showLoader(msg='Agent thinking...'){
  $('loaderMsg').textContent = msg;
  addClass('loaderOverlay','active');
}
function hideLoader(){ removeClass('loaderOverlay','active'); }

// ── Agent Log ──
let logDelay = 0;
function agentLog(steps){
  const panel = $('agentPanel');
  panel.classList.add('active');
  const log = $('agentLog');
  log.innerHTML = '';
  logDelay = 0;

  steps.forEach((step, i) => {
    setTimeout(() => {
      const el = document.createElement('div');
      el.className = 'agent-log-item';
      el.innerHTML = `<span class="step">▸</span><span class="msg">${step}</span>`;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    }, i * 350);
  });
}

function hideAgentPanel(){
  setTimeout(() => removeClass('agentPanel','active'), 2000);
}

// ── Stats Update ──
function updateStats(u){
  if(!u) return;
  state.userStats = { ...state.userStats, ...u };
  const s = state.userStats;

  $('hLevel').textContent = s.level;
  $('hXP').textContent = s.xp;
  $('hStreak').textContent = s.streak;
  $('hAccuracy').textContent = s.accuracy + '%';

  $('companionEmoji').textContent = s.companion || '🥚';
  const names = {'🥚':'EGG','🐣':'HATCHLING','🐉':'DRAGON'};
  $('companionName').textContent = names[s.companion] || 'EGG';
  const nextEvolve = {'🥚':'Level 3 → 🐣','🐣':'Level 5 → 🐉','🐉':'MAX LEVEL 🌟'};
  $('companionEvolve').textContent = nextEvolve[s.companion] || 'Level 3 → 🐣';

  const nextLvl = s.level * 50;
  const pct = Math.min(100, Math.round((s.xp / nextLvl) * 100));
  $('xpCurrent').textContent = s.xp;
  $('xpNext').textContent = nextLvl;
  $('xpFill').style.width = pct + '%';

  // Weak spots
  const ws = s.weakSpots || {};
  const wsKeys = Object.keys(ws);
  if(wsKeys.length > 0){
    addClass('weakspotSection','active');
    $('weakspotList').innerHTML = wsKeys.sort((a,b)=>ws[b]-ws[a]).slice(0,5).map(t=>`
      <div class="weakspot-item">
        <span class="ws-topic">${t}</span>
        <div class="ws-bar"><div class="ws-fill" style="width:${Math.min(100,ws[t]*20)}%"></div></div>
        <span class="ws-count">✗ ${ws[t]}x</span>
      </div>
    `).join('');
  }

  // Achievements
  if(s.achievements?.length > 0){
    addClass('achievementsSection','active');
    $('badgesGrid').innerHTML = s.achievements.map(a=>`
      <div class="badge-card">
        <span class="badge-icon">${a.split(' ')[0]}</span>
        <div class="badge-name">${a.replace(/^[\S]+\s/,'')}</div>
      </div>
    `).join('');
  }
}

function updateProgress(p){
  if(!p) return;
  state.progress = { ...state.progress, ...p };
  const pct = p.percentage || 0;

  // Ring
  const circumference = 2 * Math.PI * 26;
  const offset = circumference - (pct / 100) * circumference;
  $('ringFill').style.strokeDashoffset = offset;
  $('ringPct').textContent = pct + '%';
  $('lessonKicker').textContent = `LESSON ${p.current || 1} OF ${p.total || 1}`;
}

// ── Display Lesson ──
function displayLesson(lesson, progress){
  if(!lesson) return;
  state.lesson = lesson;

  addClass('lessonCard','active');
  hide('completeScreen');
  hide('uploadZone');
  removeClass('lessonCard','hidden');

  $('lessonTitle').textContent = lesson.title || 'Lesson';
  $('lessonTime').textContent = '⏱ ' + (lesson.estimatedTime || '10 min');
  $('lessonDiff').textContent = '★ '.repeat(lesson.difficulty||1).trim() || '★';

  $('lessonVisual').textContent = lesson.visual || 'No diagram available';
  $('lessonExplanation').textContent = lesson.explanation || '';

  if(lesson.mnemonicTip){ $('mnemonicText').textContent = lesson.mnemonicTip; show('mnemonicBox'); }
  else hide('mnemonicBox');

  if(lesson.realWorldConnection){ $('realworldText').textContent = lesson.realWorldConnection; show('realworldBox'); }
  else hide('realworldBox');

  // Mistakes
  if(lesson.commonMistakes?.length){
    show('mistakesSection');
    $('mistakesList').innerHTML = lesson.commonMistakes.map(m=>`
      <div class="mistake"><span class="mistake-x">✗</span><span>${m}</span></div>
    `).join('');
  } else hide('mistakesSection');

  // Examples
  if(lesson.examples?.length){
    show('examplesSection');
    $('examplesList').innerHTML = lesson.examples.map(e=>`<div class="example-item">${e}</div>`).join('');
  } else hide('examplesSection');

  // Key Terms
  if(lesson.keyTerms?.length){
    show('termsSection');
    $('termsList').innerHTML = lesson.keyTerms.map(t=>`<span class="term">${t}</span>`).join('');
  } else hide('termsSection');

  // Questions
  const questions = lesson.questions || [];
  state.questions = questions;
  state.answers = new Array(questions.length).fill(null);
  state.hintLevels = {};
  state.submitted = false;

  $('questionsWrap').innerHTML = questions.map((q,i) => {
    const letters = ['A','B','C','D'];
    const isWeak = q.targetedWeakSpot ? '<span class="weak-flag">🎯 TARGETS WEAK SPOT</span>' : '';
    return `
      <div class="question-block" id="qBlock_${i}">
        <div class="q-meta">
          <span class="q-num">Q${i+1}</span>
          <span class="q-diff diff-${q.difficulty||'medium'}">${(q.difficulty||'medium').toUpperCase()}</span>
          ${isWeak}
        </div>
        <div class="q-text">${q.text}</div>
        <div class="options-grid" id="opts_${i}">
          ${(q.options||[]).map((opt,j)=>`
            <button class="option" id="opt_${i}_${j}" onclick="selectOption(${i},${j},'${opt.replace(/'/g,"\\'")}')">
              <span class="opt-letter">${letters[j]||j}</span>
              <span>${opt}</span>
            </button>
          `).join('')}
        </div>
        ${q.hint ? `
          <button class="hint-btn" onclick="requestHint(${i})">
            💡 Need a hint?
          </button>
          <div class="hint-box" id="hint_${i}"></div>
        ` : ''}
      </div>
    `;
  }).join('');

  // Reset action row
  show('submitBtn'); hide('nextBtn');
  $('submitBtn').style.display = '';
  $('nextBtn').style.display = 'none';
  $('actionRow').className = 'action-row';

  // Clear diagnosis
  const d = $('diagCard');
  d.className = 'diagnosis-card';
  d.innerHTML = '';

  updateProgress(progress);
}

// ── Select Option ──
function selectOption(qIdx, optIdx, value){
  if(state.submitted) return;
  state.answers[qIdx] = value;

  // UI update
  const opts = $('opts_'+qIdx).querySelectorAll('.option');
  opts.forEach(o => o.classList.remove('selected'));
  document.getElementById(`opt_${qIdx}_${optIdx}`).classList.add('selected');
}

// ── Request Hint ──
async function requestHint(qIdx){
  const q = state.questions[qIdx];
  if(!q) return;
  const level = (state.hintLevels[qIdx] || 0) + 1;
  state.hintLevels[qIdx] = level;

  const hintBox = $(`hint_${qIdx}`);
  hintBox.textContent = '🤔 Agent thinking of a hint...';
  hintBox.classList.add('visible');

  try {
    const r = await fetch(`${API}/api/get-hint`, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ userId, question: q.text, hintLevel: Math.min(3,level), context: state.lesson?.explanation || '' })
    });
    const d = await r.json();
    if(d.success){
      const lvlLabel = ['💡 Subtle hint','🔦 Moderate hint','🔆 Strong hint'][Math.min(2,level-1)];
      hintBox.innerHTML = `<strong>${lvlLabel} (${level}/3):</strong> ${d.hint}`;
    }
  } catch {
    hintBox.textContent = q.hint || 'Think carefully about the key concepts in the question.';
  }
}

// ── Submit Answers ──
async function submitAnswers(){
  if(state.submitted) return;
  if(state.answers.includes(null)){
    toast('Please answer all questions first!','warning'); return;
  }

  state.submitted = true;
  showLoader('🤖 Agent grading and diagnosing...');

  // Grade locally
  let correctCount = 0;
  const results = state.questions.map((q, i) => ({
    correct: state.answers[i] === q.correct,
    question: q.text,
    correctAnswer: q.correct,
    studentAnswer: state.answers[i],
    topic: q.topic || state.lesson?.concept || 'general'
  }));

  results.forEach(r => { if(r.correct) correctCount++; });
  const allCorrect = correctCount === state.questions.length;

  // Highlight answers
  state.questions.forEach((q,i) => {
    const opts = $('opts_'+i).querySelectorAll('.option');
    opts.forEach(o => {
      o.disabled = true;
      const txt = o.querySelector('span:last-child').textContent.trim();
      if(txt === q.correct) o.classList.add('correct');
      else if(txt === state.answers[i] && !results[i].correct) o.classList.add('wrong');
    });
  });

  // Submit to server + get agent diagnosis
  let agentDiagnosis = null;
  try {
    const firstWrong = results.find(r => !r.correct);
    const r = await fetch(`${API}/api/submit-answer`, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        userId,
        isCorrect: allCorrect,
        question: firstWrong?.question,
        correctAnswer: firstWrong?.correctAnswer,
        studentAnswer: firstWrong?.studentAnswer,
        topic: firstWrong?.topic,
        timeSpent: 15
      })
    });
    const d = await r.json();

    if(d.success){
      updateStats(d.user);
      agentDiagnosis = d.agentDiagnosis;

      if(d.newAchievements?.length > 0){
        d.newAchievements.forEach(a => toast(`🏆 Achievement Unlocked: ${a}`,'success', 5000));
      }
    }
  } catch(err){ console.error(err); }

  hideLoader();

  // Show diagnosis card
  const dc = $('diagCard');
  if(allCorrect){
    dc.className = 'diagnosis-card correct visible';
    dc.innerHTML = `
      <div class="diag-header">
        <span class="diag-icon">🎉</span>
        <div>
          <div class="diag-title">Perfect Score! ${correctCount}/${state.questions.length}</div>
          <div class="diag-meta">+10 XP EARNED · STREAK ${state.userStats.streak}</div>
        </div>
      </div>
      <div class="diag-body">Excellent work! The agent confirms you've understood this material. Keep this momentum going!</div>
    `;
    toast(`✨ ${correctCount}/${state.questions.length} correct! +10 XP`,'success');
  } else {
    dc.className = 'diagnosis-card wrong visible';
    let bodyHTML = `
      <div class="diag-header">
        <span class="diag-icon">🧠</span>
        <div>
          <div class="diag-title">${correctCount}/${state.questions.length} Correct</div>
          <div class="diag-meta">AGENT DIAGNOSING MISCONCEPTIONS</div>
        </div>
      </div>
    `;

    if(agentDiagnosis){
      bodyHTML += `<div class="diag-body">${agentDiagnosis}</div>`;
    } else {
      const firstWrong = results.find(r=>!r.correct);
      if(firstWrong) bodyHTML += `<div class="diag-body">Review the explanation above for ${firstWrong.topic}. The correct answer was: <strong>${firstWrong.correctAnswer}</strong></div>`;
    }
    dc.innerHTML = bodyHTML;
    toast(`📚 ${correctCount}/${state.questions.length} correct. Agent has diagnosed your mistakes.`,'info');
  }

  // Show Next button
  $('submitBtn').style.display = 'none';
  $('nextBtn').style.display = '';
  $('actionRow').className = 'action-row';
}

// ── Next Lesson ──
async function nextLesson(){
  showLoader('➡️ Agent loading next lesson...');
  try {
    const r = await fetch(`${API}/api/next-lesson`,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({userId})
    });
    const d = await r.json();

    if(d.success){
      if(d.user) updateStats(d.user);

      if(d.hasNext){
        if(d.adaptiveMessage) toast(`🤖 ${d.adaptiveMessage}`,'info',5000);
        await loadLesson();
      } else {
        // Complete
        hideLoader();
        removeClass('lessonCard','active');
        addClass('completeScreen','active');
        const u = state.userStats;
        $('cAccuracy').textContent = u.accuracy + '%';
        $('cLessons').textContent = state.progress.completedLessons || state.progress.total;
        $('cXP').textContent = u.xp;
        toast('🏆 Course complete! Amazing work!','success',8000);
        return;
      }
    }
  } catch(err){ toast('Failed to load next lesson','error'); }
  hideLoader();
}

// ── Load Lesson ──
async function loadLesson(){
  showLoader('📚 Agent retrieving your lesson...');
  try {
    const r = await fetch(`${API}/api/get-lesson`,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({userId})
    });
    const d = await r.json();

    if(d.success && d.lesson){
      if(d.user) updateStats(d.user);
      displayLesson(d.lesson, d.progress);
    } else {
      toast(d.message || 'No lesson available','info');
    }
  } catch(err){ toast('Failed to load lesson','error'); }
  hideLoader();
}

// ── Upload PDF ──
async function uploadPDF(file){
  if(!file || file.type !== 'application/pdf'){
    toast('Please upload a valid PDF file','error'); return;
  }
  if(file.size > 10 * 1024 * 1024){
    toast('File too large. Max 10MB','error'); return;
  }

  const agentSteps = [
    '🔍 Parsing PDF structure...',
    '🤖 Initializing agent loop with 8 tools...',
    '📊 Tool: analyze_student_profile → profiling you',
    '🧩 Tool: extract_key_concepts → mapping the content',
    '📚 Tool: generate_lesson → crafting personalized lessons',
    '❓ Tool: generate_adaptive_questions → targeting your level',
    '🎯 Tool: update_learning_path → optimizing your journey',
    '✅ Curriculum ready!'
  ];
  agentLog(agentSteps);
  showLoader('🤖 Agent analyzing PDF...');
  $('uploadZone').style.opacity = '0.5';

  const form = new FormData();
  form.append('pdf', file);
  form.append('userId', userId);

  try {
    const r = await fetch(`${API}/api/upload-pdf`,{ method:'POST', body:form });
    const d = await r.json();

    if(d.success){
      if(d.user) updateStats(d.user);
      toast(`✅ ${d.lessonsCreated} lessons generated by agent!`,'success',5000);

      // Show clarifying question if provided
      if(d.clarifyingQuestion){
        showClarifyingQuestion(d.clarifyingQuestion);
        hideLoader();
        hideAgentPanel();
      } else {
        hideLoader();
        hideAgentPanel();
        await loadLesson();
      }
      $('uploadZone').style.display = 'none';
    } else {
      toast(`Error: ${d.error}`,'error');
      hideLoader();
      hideAgentPanel();
    }
  } catch(err){
    toast('Cannot connect to server. Start with: node index.js','error',0);
    hideLoader();
    removeClass('agentPanel','active');
  }
  $('uploadZone').style.opacity = '1';
}

// ── Clarifying Question ──
function showClarifyingQuestion(text){
  const card = $('clarifyCard');
  card.classList.add('active');

  // Parse if JSON
  let questionText = text;
  let options = ['Beginner','Some experience','Advanced','Expert'];
  try {
    const parsed = JSON.parse(text);
    questionText = parsed.question || text;
    if(parsed.followUpOptions) options = parsed.followUpOptions;
  } catch {
    // Use as-is
    const match = text.match(/["']([^"']+)["']/);
    if(match) questionText = match[1];
  }

  $('clarifyQ').textContent = questionText;
  $('clarifyOpts').innerHTML = options.map(o=>`
    <button class="clarify-btn" onclick="answerClarify('${o.replace(/'/g,"\\'")}')">${o}</button>
  `).join('');
}

async function answerClarify(answer){
  card = $('clarifyCard');
  card.classList.remove('active');
  toast(`🤖 Agent noted: ${answer}`,'info',3000);
  await loadLesson();
}

// ── Setup Events ──
function setup(){
  const zone = $('uploadZone');
  const input = $('fileInput');

  zone.addEventListener('click', () => input.click());
  input.addEventListener('change', e => { if(e.target.files[0]) uploadPDF(e.target.files[0]); });

  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('drag'));
  zone.addEventListener('drop', e => {
    e.preventDefault(); zone.classList.remove('drag');
    const f = e.dataTransfer.files[0];
    if(f) uploadPDF(f);
  });

  $('submitBtn').addEventListener('click', submitAnswers);
  $('nextBtn').addEventListener('click', nextLesson);
}

// ── Init ──
async function init(){
  setup();
  try {
    const r = await fetch(`${API}/`);
    if(r.ok) toast('🤖 Agent server connected','success',3000);
  } catch {
    toast('⚠️ Server offline. Run: node index.js','error',0);
  }
}

init();
</script>
