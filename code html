  margin-top:10px;
}
.hint-btn:hover{border-color:var(--purple);color:var(--purple)}
.hint-box{
  display:none;
  margin-top:10px;
  padding:12px 16px;
  background:rgba(123,47,255,0.06);
  border:1px solid rgba(123,47,255,0.15);
  border-radius:10px;
  font-size:0.88rem;
  line-height:1.6;
  color:var(--purple);
}
.hint-box.visible{display:block;animation:cardIn 0.3s ease}

/* ── Feedback / Diagnosis ── */
.diagnosis-card{
