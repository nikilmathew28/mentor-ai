<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MENTOR.AI — Agentic Learning System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --ink:#0a0a0f;
  --paper:#f5f3ee;
  --cream:#ede9e1;
  --accent:#ff4d1c;
  --accent2:#1c6eff;
  --gold:#f5a623;
  --green:#1db954;
  --purple:#7b2fff;
  --surface:rgba(255,255,255,0.7);
  --border:rgba(10,10,15,0.12);
  --font-display:'Syne',sans-serif;
  --font-mono:'Space Mono',monospace;
  --font-body:'DM Sans',sans-serif;
}

body{
  font-family:var(--font-body);
  background:var(--paper);
  color:var(--ink);
  min-height:100vh;
  overflow-x:hidden;
  cursor:none;
}

/* ── Custom Cursor ── */
#cursor{
  position:fixed;
  width:12px;height:12px;
  background:var(--accent);
  border-radius:50%;
  pointer-events:none;
  z-index:10000;
  transform:translate(-50%,-50%);
  transition:transform 0.1s,width 0.2s,height 0.2s,background 0.2s;
  mix-blend-mode:multiply;
}
#cursor-ring{
  position:fixed;
  width:36px;height:36px;
  border:2px solid var(--accent);
  border-radius:50%;
  pointer-events:none;
  z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform 0.15s ease-out,width 0.2s,height 0.2s,opacity 0.2s;
  opacity:0.5;
}
body:hover #cursor{opacity:1}

/* ── Background Grid ── */
body::before{
  content:'';
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size:48px 48px;
  z-index:0;
  pointer-events:none;
}

/* ── Floating Orbs ── */
.orb{
  position:fixed;
  border-radius:50%;
  filter:blur(80px);
  pointer-events:none;
  z-index:0;
  opacity:0.18;
  animation:orbFloat 15s ease-in-out infinite;
}
.orb1{width:500px;height:500px;background:var(--accent);top:-10%;left:-5%;animation-delay:0s}
.orb2{width:400px;height:400px;background:var(--accent2);bottom:-10%;right:-5%;animation-delay:-7s}
.orb3{width:300px;height:300px;background:var(--purple);top:40%;left:60%;animation-delay:-3s}
@keyframes orbFloat{
  0%,100%{transform:translate(0,0) scale(1)}
  33%{transform:translate(30px,-30px) scale(1.05)}
  66%{transform:translate(-20px,20px) scale(0.95)}
}

/* ── Layout ── */
.app{
  position:relative;z-index:1;
  max-width:1100px;
  margin:0 auto;
  padding:0 32px 80px;
}

/* ── Header ── */
.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:28px 0 24px;
  border-bottom:1px solid var(--border);
  margin-bottom:48px;
}
.logo{
  font-family:var(--font-display);
  font-size:1.4rem;
  font-weight:800;
  letter-spacing:-0.03em;
  display:flex;align-items:center;gap:10px;
}
.logo-dot{
  width:10px;height:10px;
  background:var(--accent);
  border-radius:50%;
  animation:logoBlink 2s ease-in-out infinite;
}
@keyframes logoBlink{0%,100%{opacity:1}50%{opacity:0.3}}
.logo-tag{
  font-family:var(--font-mono);
  font-size:0.7rem;
  background:var(--accent);
  color:white;
  padding:3px 8px;
  border-radius:3px;
  letter-spacing:0.05em;
}

/* ── Stats Bar ── */
.stats-bar{
  display:flex;gap:12px;
  align-items:center;
  flex-wrap:wrap;
}
.stat-pill{
  display:flex;align-items:center;gap:8px;
  background:var(--surface);
  backdrop-filter:blur(12px);
  border:1px solid var(--border);
  border-radius:100px;
  padding:8px 16px;
  font-size:0.82rem;
  font-weight:600;
  font-family:var(--font-mono);
  transition:all 0.3s;
}
.stat-pill:hover{border-color:var(--accent);transform:translateY(-2px)}
.stat-pill .icon{font-size:1rem}
.stat-val{font-size:0.95rem;font-weight:700;color:var(--accent)}

/* ── Hero ── */
.hero{
  display:grid;
  grid-template-columns:1fr auto;
  gap:48px;
  align-items:center;
  margin-bottom:56px;
}
.hero-text h1{
  font-family:var(--font-display);
  font-size:clamp(2.5rem,6vw,4.5rem);
  font-weight:800;
  line-height:0.95;
  letter-spacing:-0.04em;
  margin-bottom:20px;
}
.hero-text h1 em{
  font-style:normal;
  color:var(--accent);
  position:relative;
}
.hero-text h1 em::after{
  content:'';
  position:absolute;
  bottom:-4px;left:0;right:0;
  height:4px;
  background:var(--accent);
  border-radius:2px;
}
.hero-text p{
  color:rgba(10,10,15,0.6);
  font-size:1.05rem;
  line-height:1.7;
  max-width:480px;
  margin-bottom:28px;
}
.agent-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--ink);
  color:var(--paper);
  border-radius:6px;
  padding:10px 20px;
  font-family:var(--font-mono);
  font-size:0.78rem;
  letter-spacing:0.04em;
}
.agent-badge .dot{
  width:8px;height:8px;
  background:var(--green);
  border-radius:50%;
  animation:pulse 1.5s ease-in-out infinite;
  box-shadow:0 0 0 0 rgba(29,185,84,0.4);
}
@keyframes pulse{
  0%{box-shadow:0 0 0 0 rgba(29,185,84,0.4)}
  70%{box-shadow:0 0 0 8px rgba(29,185,84,0)}
  100%{box-shadow:0 0 0 0 rgba(29,185,84,0)}
}

/* ── Companion ── */
.companion-card{
  width:200px;
  background:var(--surface);
  backdrop-filter:blur(12px);
  border:1px solid var(--border);
  border-radius:24px;
  padding:28px 24px;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.companion-card::before{
  content:'';
  position:absolute;
  top:-50%;left:-50%;
  width:200%;height:200%;
  background:conic-gradient(from 0deg, transparent 0%, rgba(255,77,28,0.05) 50%, transparent 100%);
  animation:companionSpin 8s linear infinite;
}
@keyframes companionSpin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.companion-emoji{
  font-size:72px;
  display:block;
  margin-bottom:12px;
  animation:companionBounce 3s ease-in-out infinite;
  position:relative;z-index:1;
}
@keyframes companionBounce{
  0%,100%{transform:translateY(0) scale(1)}
  50%{transform:translateY(-12px) scale(1.05)}
}
.companion-name{
  font-family:var(--font-display);
  font-weight:700;
  font-size:0.9rem;
  letter-spacing:0.05em;
  text-transform:uppercase;
  color:var(--accent);
  position:relative;z-index:1;
}
.companion-evolve{
  font-size:0.72rem;
  color:rgba(10,10,15,0.4);
  margin-top:6px;
  font-family:var(--font-mono);
  position:relative;z-index:1;
}

/* ── XP Bar ── */
.xp-track{
  background:var(--surface);
  backdrop-filter:blur(12px);
  border:1px solid var(--border);
  border-radius:16px;
  padding:20px 24px;
  margin-bottom:32px;
}
.xp-header{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:12px;
}
.xp-label{
  font-family:var(--font-mono);
  font-size:0.75rem;
  letter-spacing:0.08em;
  text-transform:uppercase;
  opacity:0.5;
}
.xp-value{
  font-family:var(--font-display);
  font-weight:800;
  font-size:1.1rem;
  color:var(--accent);
}
.xp-bar{
  height:8px;
  background:var(--cream);
  border-radius:100px;
  overflow:hidden;
}
.xp-fill{
  height:100%;
  background:linear-gradient(90deg,var(--accent),var(--purple));
  border-radius:100px;
  transition:width 0.8s cubic-bezier(0.4,0,0.2,1);
  position:relative;
  overflow:hidden;
}
.xp-fill::after{
  content:'';
  position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent);
  animation:shimmer 2s infinite;
}
@keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}

/* ── Upload Zone ── */
.upload-zone{
  border:2px dashed var(--border);
  border-radius:20px;
  padding:56px 40px;
  text-align:center;
  cursor:pointer;
  transition:all 0.3s cubic-bezier(0.4,0,0.2,1);
  position:relative;
  overflow:hidden;
  background:var(--surface);
  backdrop-filter:blur(12px);
  margin-bottom:40px;
}
.upload-zone:hover,.upload-zone.drag{
  border-color:var(--accent);
  background:rgba(255,77,28,0.04);
  transform:scale(1.01);
}
.upload-zone.drag{border-style:solid;background:rgba(255,77,28,0.08)}
.upload-zone::before{
  content:'';
  position:absolute;
  top:50%;left:50%;
  width:200px;height:200px;
  background:radial-gradient(circle,rgba(255,77,28,0.08),transparent);
  transform:translate(-50%,-50%);
  border-radius:50%;
  transition:all 0.5s;
  pointer-events:none;
}
.upload-zone:hover::before,.upload-zone.drag::before{
  width:400px;height:400px;
}
.upload-icon-wrap{
  width:80px;height:80px;
  border-radius:20px;
  background:var(--ink);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 24px;
  font-size:2rem;
  transition:all 0.3s;
  position:relative;z-index:1;
}
.upload-zone:hover .upload-icon-wrap{
  background:var(--accent);
  transform:rotate(-6deg) scale(1.1);
}
.upload-title{
  font-family:var(--font-display);
  font-size:1.6rem;
  font-weight:800;
  letter-spacing:-0.02em;
  margin-bottom:10px;
  position:relative;z-index:1;
}
.upload-sub{
  color:rgba(10,10,15,0.5);
  font-size:0.9rem;
  margin-bottom:20px;
  position:relative;z-index:1;
}
.upload-formats{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;position:relative;z-index:1}
.format-chip{
  font-family:var(--font-mono);
  font-size:0.7rem;
  padding:5px 12px;
  border:1px solid var(--border);
  border-radius:100px;
  letter-spacing:0.05em;
  background:white;
}
input[type=file]{display:none}

/* ── Agent Status Panel ── */
.agent-panel{
  display:none;
  background:var(--ink);
  color:var(--paper);
  border-radius:16px;
  padding:24px 28px;
  margin-bottom:32px;
  font-family:var(--font-mono);
  font-size:0.82rem;
  position:relative;
  overflow:hidden;
}
.agent-panel.active{display:block}
.agent-panel::before{
  content:'';
  position:absolute;
  top:0;left:0;right:0;
  height:2px;
  background:linear-gradient(90deg,var(--accent),var(--purple),var(--accent2));
  background-size:200% 100%;
  animation:agentLine 2s linear infinite;
}
@keyframes agentLine{0%{background-position:200% 0}100%{background-position:0% 0}}
.agent-header{
  display:flex;align-items:center;gap:10px;
  margin-bottom:16px;
  opacity:0.6;
  font-size:0.7rem;
  letter-spacing:0.12em;
  text-transform:uppercase;
}
.agent-thinking{
  display:flex;gap:4px;align-items:center;
  font-size:0.75rem;
  margin-left:auto;
}
.agent-dot{
  width:4px;height:4px;
  background:var(--green);
  border-radius:50%;
  animation:agentDot 1.2s ease-in-out infinite;
}
.agent-dot:nth-child(2){animation-delay:0.2s}
.agent-dot:nth-child(3){animation-delay:0.4s}
@keyframes agentDot{0%,100%{opacity:0.2;transform:scale(1)}50%{opacity:1;transform:scale(1.5)}}
.agent-log{
  display:flex;flex-direction:column;gap:6px;
  max-height:120px;
  overflow-y:auto;
}
.agent-log-item{
  display:flex;align-items:flex-start;gap:8px;
  opacity:0;
  animation:logFade 0.4s forwards;
}
@keyframes logFade{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
.agent-log-item .step{color:var(--accent);min-width:14px}
.agent-log-item .msg{color:rgba(245,243,238,0.8);line-height:1.5}

/* ── Clarifying Question ── */
.clarify-card{
  display:none;
  background:linear-gradient(135deg,rgba(123,47,255,0.08),rgba(28,110,255,0.06));
  border:1px solid rgba(123,47,255,0.2);
  border-radius:16px;
  padding:24px 28px;
  margin-bottom:32px;
  animation:cardIn 0.5s cubic-bezier(0.4,0,0.2,1);
}
.clarify-card.active{display:block}
.clarify-header{
  display:flex;align-items:center;gap:10px;
  font-family:var(--font-mono);
  font-size:0.7rem;
  text-transform:uppercase;
  letter-spacing:0.1em;
  color:var(--purple);
  margin-bottom:14px;
}
.clarify-q{
  font-size:1.05rem;
  font-weight:600;
  margin-bottom:16px;
  line-height:1.5;
}
.clarify-options{display:flex;gap:10px;flex-wrap:wrap}
.clarify-btn{
  padding:10px 20px;
  border:1px solid var(--border);
  border-radius:100px;
  background:white;
  cursor:pointer;
  font-family:var(--font-body);
  font-size:0.9rem;
  font-weight:500;
  transition:all 0.2s;
}
.clarify-btn:hover{
  border-color:var(--purple);
  background:rgba(123,47,255,0.06);
  transform:translateY(-2px);
}

/* ── Lesson Card ── */
.lesson-card{
  display:none;
  animation:cardIn 0.5s cubic-bezier(0.4,0,0.2,1);
}
.lesson-card.active{display:block}
@keyframes cardIn{
  from{opacity:0;transform:translateY(24px)}
  to{opacity:1;transform:translateY(0)}
}

.lesson-top{
  display:flex;justify-content:space-between;align-items:flex-start;
  margin-bottom:32px;
  padding-bottom:24px;
  border-bottom:1px solid var(--border);
  gap:16px;
  flex-wrap:wrap;
}
.lesson-info{}
.lesson-kicker{
  font-family:var(--font-mono);
  font-size:0.7rem;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color:var(--accent);
  margin-bottom:8px;
}
.lesson-title{
  font-family:var(--font-display);
  font-size:clamp(1.5rem,3vw,2.2rem);
  font-weight:800;
  letter-spacing:-0.03em;
  line-height:1.1;
}
.lesson-chips{
  display:flex;gap:8px;margin-top:12px;flex-wrap:wrap;
}
.chip{
  font-family:var(--font-mono);
  font-size:0.7rem;
  padding:4px 12px;
  border-radius:100px;
  border:1px solid var(--border);
  letter-spacing:0.04em;
}
.chip-time{background:#fff7ed;border-color:rgba(245,166,35,0.3);color:#b45309}
.chip-diff{background:#f0fdf4;border-color:rgba(29,185,84,0.3);color:#15803d}

/* Progress tracker */
.progress-ring-wrap{
  display:flex;flex-direction:column;align-items:center;gap:6px;min-width:80px;
}
.progress-ring{
  transform:rotate(-90deg);
}
.ring-bg{fill:none;stroke:var(--cream);stroke-width:4}
.ring-fill{
  fill:none;stroke:var(--accent);stroke-width:4;
  stroke-linecap:round;
  stroke-dasharray:164;
  stroke-dashoffset:164;
  transition:stroke-dashoffset 1s cubic-bezier(0.4,0,0.2,1);
}
.ring-pct{
  font-family:var(--font-display);
  font-weight:800;
  font-size:0.75rem;
  color:var(--accent);
}

/* ── Content Sections ── */
.section{
  background:var(--surface);
  backdrop-filter:blur(12px);
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
  margin-bottom:20px;
  position:relative;
}
.section-label{
  font-family:var(--font-mono);
  font-size:0.65rem;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:rgba(10,10,15,0.4);
  margin-bottom:14px;
  display:flex;align-items:center;gap:8px;
}
.section-label::after{
  content:'';
  flex:1;
  height:1px;
  background:var(--border);
}

/* Visual Box */
.visual-pre{
  font-family:var(--font-mono);
  font-size:0.78rem;
  line-height:1.7;
  white-space:pre;
  overflow-x:auto;
  color:var(--ink);
  padding:4px 0;
}

/* Mnemonic badge */
.mnemonic{
  display:inline-flex;align-items:center;gap:8px;
  background:linear-gradient(135deg,#fff7ed,#fef3c7);
  border:1px solid #fed7aa;
  border-radius:8px;
  padding:10px 16px;
  font-size:0.88rem;
  margin-top:12px;
  width:100%;
}
.mnemonic .icon{font-size:1.1rem}
.mnemonic strong{font-weight:600;color:#b45309}

/* Real world */
.realworld{
  display:flex;align-items:flex-start;gap:12px;
  background:linear-gradient(135deg,#f0fdf4,#dcfce7);
  border:1px solid #bbf7d0;
  border-radius:8px;
  padding:12px 16px;
  font-size:0.88rem;
  margin-top:12px;
  color:#166534;
}

/* Common mistakes */
.mistake{
  display:flex;align-items:flex-start;gap:10px;
  padding:10px 0;
  border-bottom:1px solid var(--border);
  font-size:0.9rem;
  color:rgba(10,10,15,0.8);
}
.mistake:last-child{border:none}
.mistake-x{color:#dc2626;font-weight:700;font-size:1rem}

/* Examples */
.example-item{
  padding:14px 16px;
  background:white;
  border-radius:10px;
  border-left:3px solid var(--gold);
  margin-bottom:10px;
  font-size:0.9rem;
  line-height:1.6;
  transition:transform 0.2s,box-shadow 0.2s;
}
.example-item:hover{transform:translateX(6px);box-shadow:0 4px 16px rgba(0,0,0,0.06)}

/* Key Terms */
.terms-wrap{display:flex;flex-wrap:wrap;gap:8px}
.term{
  padding:8px 16px;
  background:white;
  border:1px solid var(--border);
  border-radius:100px;
  font-size:0.82rem;
  font-weight:500;
  transition:all 0.2s;
  cursor:default;
}
.term:hover{border-color:var(--accent2);background:rgba(28,110,255,0.04);transform:scale(1.03)}

/* ── Questions ── */
.question-block{
  background:white;
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
  margin-bottom:16px;
  transition:box-shadow 0.3s;
}
.question-block:hover{box-shadow:0 8px 32px rgba(0,0,0,0.06)}
.q-meta{
  display:flex;align-items:center;gap:8px;
  margin-bottom:14px;
}
.q-num{
  font-family:var(--font-mono);
  font-size:0.7rem;
  background:var(--ink);
  color:var(--paper);
  padding:3px 10px;
  border-radius:100px;
  letter-spacing:0.05em;
}
.q-diff{
  font-family:var(--font-mono);
  font-size:0.7rem;
  padding:3px 10px;
  border-radius:100px;
  letter-spacing:0.04em;
}
.diff-easy{background:#dcfce7;color:#15803d}
.diff-medium{background:#fef3c7;color:#b45309}
.diff-hard{background:#fee2e2;color:#dc2626}
.weak-flag{
  font-family:var(--font-mono);
  font-size:0.65rem;
  background:rgba(255,77,28,0.1);
  color:var(--accent);
  padding:3px 10px;
  border-radius:100px;
  border:1px solid rgba(255,77,28,0.2);
  margin-left:auto;
}

.q-text{
  font-size:1rem;
  font-weight:600;
  line-height:1.6;
  margin-bottom:16px;
}

.options-grid{display:grid;gap:8px}
.option{
  display:flex;align-items:center;gap:12px;
  padding:14px 18px;
  border:1.5px solid var(--border);
  border-radius:12px;
  cursor:pointer;
  transition:all 0.2s cubic-bezier(0.4,0,0.2,1);
  font-size:0.92rem;
  background:white;
  text-align:left;
  width:100%;
}
.option:hover{border-color:var(--accent2);background:rgba(28,110,255,0.03);transform:translateX(4px)}
.option.selected{border-color:var(--accent2);background:rgba(28,110,255,0.06);font-weight:500}
.option.correct{border-color:var(--green);background:rgba(29,185,84,0.08);color:#166534}
.option.wrong{border-color:#ef4444;background:rgba(239,68,68,0.06);color:#dc2626;opacity:0.7}
.option:disabled{cursor:default;transform:none}
.opt-letter{
