}
.option.selected .opt-letter{background:var(--accent2);color:white}
.option.correct .opt-letter{background:var(--green);color:white}
.option.wrong .opt-letter{background:#ef4444;color:white}

/* Hint button */
.hint-btn{
  display:flex;align-items:center;gap:6px;
  background:none;border:1px solid var(--border);
  border-radius:100px;
  padding:6px 14px;
  font-family:var(--font-mono);
  font-size:0.7rem;
  cursor:pointer;
  color:rgba(10,10,15,0.5);
