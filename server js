// ── Next Lesson ─────────────────────────────
app.post('/api/next-lesson', async (req, res) => {
  try {
    const { userId } = req.body;
    const user = users.get(userId);
    const data = pdfStore.get(userId);

    if (!user || !data) return res.json({ success: false, hasNext: false });

    const nextIdx = (user.currentLessonIndex || 0) + 1;
    const prevId = data.lessons[user.currentLessonIndex]?.id;
    if (prevId && !user.completedLessons.includes(prevId)) user.completedLessons.push(prevId);

    if (nextIdx < data.lessons.length) {
      user.currentLessonIndex = nextIdx;

      // 🤖 Check if learning path needs adjustment
      const weakSpotTopics = Object.keys(user.weakSpots || {});
      let adaptiveMessage = null;
      if (weakSpotTopics.length > 0) {
        adaptiveMessage = `Agent noticed you're struggling with: ${weakSpotTopics[0]}. Next lesson will reinforce this.`;
      }

      res.json({
        success: true,
        hasNext: true,
        adaptiveMessage,
        nextLesson: { index: nextIdx, title: data.lessons[nextIdx]?.title, total: data.lessons.length },
        user: { level: user.level, xp: user.xp, companion: user.companion }
      });
    } else {
      user.xp += 100;
      if (!user.achievements.includes('🏆 Course Master')) user.achievements.push('🏆 Course Master');

      res.json({
        success: true,
        hasNext: false,
        message: '🎉 Course complete! Incredible work!',
        summary: {
          totalLessons: data.lessons.length,
          mastery: Math.round((user.completedLessons.length / data.lessons.length) * 100),
          finalAccuracy: user.accuracy,
          bonusXP: 100,
          weakSpotsSummary: Object.keys(user.weakSpots || {})
        },
        user: { level: user.level, xp: user.xp, companion: user.companion, achievements: user.achievements }
      });
    }
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// ── Progress ────────────────────────────────
app.get('/api/progress/:userId', (req, res) => {
  try {
    const { userId } = req.params;
    const user = users.get(userId);
    const data = pdfStore.get(userId);

    if (!user) return res.json({ success: true, exists: false });

    const totalLessons = data?.lessons?.length || 0;
    const completedLessons = user.completedLessons?.length || 0;

    res.json({
      success: true, exists: true,
      user: {
        level: user.level, xp: user.xp, companion: user.companion,
        streak: user.streak, highestStreak: user.highestStreak,
        accuracy: user.accuracy, totalQuestions: user.totalQuestions,
        achievements: user.achievements, weakSpots: user.weakSpots,
        learningPace: user.learningPace
      },
      progress: {
        totalLessons, currentLesson: (user.currentLessonIndex || 0) + 1,
        completedLessons,
        masteryPercentage: totalLessons > 0 ? Math.round((completedLessons / totalLessons) * 100) : 0
      }
    });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

