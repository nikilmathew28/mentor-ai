// ══════════════════════════════════════════════
// TOOL EXECUTION ENGINE
// ══════════════════════════════════════════════
async function executeTool(toolName, toolInput, userId) {
  const user = users.get(userId) || newUser(userId);
  const pdfData = pdfStore.get(userId);
  const memory = agentMemory.get(userId) || { conversationHistory: [], insights: [] };

  console.log(`🔧 Executing tool: ${toolName}`);

  switch (toolName) {

    case "analyze_student_profile": {
      const weakSpotsSorted = Object.entries(user.weakSpots || {})
        .sort((a, b) => b[1] - a[1])
        .slice(0, 5)
        .map(([topic, count]) => ({ topic, failCount: count }));

      const recentPerf = (user.performanceHistory || []).slice(-10);
      const recentAccuracy = recentPerf.length > 0
        ? Math.round(recentPerf.filter(r => r.correct).length / recentPerf.length * 100)
        : user.accuracy;

      return {
        profile: {
          level: user.level,
          xp: user.xp,
          accuracy: user.accuracy,
          recentAccuracy,
          streak: user.streak,
          learningPace: user.learningPace,
          learningStyle: user.learningStyle,
          weakSpots: weakSpotsSorted,
          masteredTopics: user.masteredTopics || [],
          totalSessions: user.sessionCount,
          engagementScore: Math.min(100, (user.streak * 5) + (user.accuracy * 0.5)),
          recommendation: recentAccuracy > 80 ? "increase_difficulty" :
                          recentAccuracy < 40 ? "remediation_needed" : "maintain_pace"
        }
      };
    }

    case "extract_key_concepts": {
      // This would call Claude again for analysis — for now return structure
      const text = toolInput.text || '';
      const words = text.split(/\s+/);
      // Simple heuristic extraction
      const sentences = text.match(/[^.!?]+[.!?]+/g) || [];
      return {
        conceptMap: {
          primaryTopic: "Extracted from PDF",
          sections: sentences.slice(0, 5).map((s, i) => ({
            id: i + 1,
            summary: s.trim().substring(0, 100),
            importance: "high"
          })),
          estimatedDifficulty: toolInput.targetLevel <= 3 ? "beginner" : "intermediate",
          wordCount: words.length
        }
      };
    }

    case "generate_lesson": {
      // Call Claude to actually generate the lesson content
      const lessonPrompt = `You are an expert teacher. Generate a complete lesson for:

CONCEPT: ${toolInput.concept}
DIFFICULTY: ${toolInput.difficulty}/5
STUDENT WEAK SPOTS: ${(toolInput.studentWeakSpots || []).join(', ') || 'None identified'}
LEARNING STYLE: ${toolInput.learningStyle || 'visual'}

PDF CONTEXT:
${toolInput.pdfContext.substring(0, 2000)}

Generate a lesson with this EXACT JSON structure (return ONLY JSON):
{
  "id": ${Date.now()},
  "title": "emoji + engaging title",
  "concept": "${toolInput.concept}",
  "difficulty": ${toolInput.difficulty},
  "visual": "detailed multi-line ASCII art diagram with boxes, arrows, and labels",
  "explanation": "4-5 sentence comprehensive explanation adapted to ${toolInput.learningStyle} learning style",
  "examples": ["3 detailed examples from the PDF context"],
  "keyTerms": ["5-7 key terms"],
  "mnemonicTip": "A memory trick or mnemonic to remember this concept",
  "realWorldConnection": "How this connects to real life",
  "commonMistakes": ["2-3 common mistakes students make"],
  "summary": "2-3 sentence summary",
  "estimatedTime": "X minutes",
  "prerequisites": []
}`;

      const resp = await anthropic.messages.create({
        model: "claude-sonnet-4-5",
        max_tokens: 2000,
        messages: [{ role: "user", content: lessonPrompt }]
      });

      let text = resp.content[0].text;
      const match = text.match(/```(?:json)?\n?([\s\S]*?)\n?```/) || text.match(/(\{[\s\S]*\})/);
      if (match) text = match[1];

      try {
        return { lesson: JSON.parse(text.trim()) };
      } catch {
        return { lesson: { title: toolInput.concept, explanation: text, difficulty: toolInput.difficulty } };
      }
    }

    case "generate_adaptive_questions": {
      const qPrompt = `Generate ${toolInput.questionCount || 3} adaptive quiz questions for:

TOPIC: ${toolInput.topic}
STUDENT WEAK SPOTS: ${(toolInput.weakSpots || []).join(', ') || 'None'}
RECENT ACCURACY: ${toolInput.recentAccuracy || 70}%

PDF CONTEXT:
${toolInput.pdfContext.substring(0, 1500)}

Rules:
- If accuracy < 50%: make 2 easy reinforcement + 1 medium question
- If accuracy 50-75%: make 1 easy + 1 medium + 1 hard
- If accuracy > 75%: make 1 medium + 2 hard challenge questions
- Target weak spots specifically

Return ONLY JSON array:
[
  {
    "id": 1,
    "text": "question text",
    "type": "multiple_choice",
    "options": ["A) option", "B) option", "C) option", "D) option"],
    "correct": "A) option",
    "explanation": "why this is correct",
    "difficulty": "easy/medium/hard",
    "topic": "specific topic",
    "targetedWeakSpot": true/false,
    "hint": "a subtle hint if student is stuck"
  }
]`;

      const resp = await anthropic.messages.create({
        model: "claude-sonnet-4-5",
        max_tokens: 2000,
        messages: [{ role: "user", content: qPrompt }]
      });

      let text = resp.content[0].text;
      const match = text.match(/```(?:json)?\n?([\s\S]*?)\n?```/) || text.match(/(\[[\s\S]*\])/);
      if (match) text = match[1];

      try {
        return { questions: JSON.parse(text.trim()) };
      } catch {
        return { questions: [] };
      }
    }

    case "diagnose_misconception": {
      const diagPrompt = `A student answered a question incorrectly. Diagnose the misconception.

QUESTION: ${toolInput.question}
CORRECT ANSWER: ${toolInput.correctAnswer}
STUDENT ANSWERED: ${toolInput.studentAnswer}
TOPIC: ${toolInput.topic}
CONTEXT: ${(toolInput.context || '').substring(0, 500)}

Provide:
1. The likely misconception
2. A targeted, empathetic remediation explanation (2-3 sentences)
3. An analogy to help understand the correct concept
4. A follow-up mini-challenge to solidify understanding

Return JSON:
{
  "misconception": "what the student likely misunderstood",
  "remediation": "targeted explanation",
  "analogy": "helpful real-world analogy",
  "encouragement": "motivating message",
  "miniChallenge": "a simpler version of the question to rebuild confidence"
}`;

      const resp = await anthropic.messages.create({
        model: "claude-sonnet-4-5",
        max_tokens: 800,
        messages: [{ role: "user", content: diagPrompt }]
      });

      let text = resp.content[0].text;
      const match = text.match(/```(?:json)?\n?([\s\S]*?)\n?```/) || text.match(/(\{[\s\S]*\})/);
      if (match) text = match[1];

      try {
        return JSON.parse(text.trim());
      } catch {
        return {
          misconception: "Misunderstanding of core concept",
          remediation: resp.content[0].text,
          analogy: "Think of it like...",
          encouragement: "Keep going, you're learning!",
          miniChallenge: null
        };
      }
    }

    case "generate_clarifying_question": {
      const clPrompt = `Generate ONE intelligent clarifying question to understand what the student needs.

SITUATION: ${toolInput.situation}
STUDENT LEVEL: ${toolInput.studentProfile?.level || 1}
ACCURACY: ${toolInput.studentProfile?.accuracy || 0}%

The question should help personalize their learning. Return JSON:
{
  "question": "the clarifying question",
  "purpose": "why this helps personalize learning",
  "followUpOptions": ["option1", "option2", "option3"]
}`;

      const resp = await anthropic.messages.create({
        model: "claude-sonnet-4-5",
        max_tokens: 400,
        messages: [{ role: "user", content: clPrompt }]
      });

      let text = resp.content[0].text;
      const match = text.match(/(\{[\s\S]*\})/);
      if (match) text = match[1];

      try {
        return JSON.parse(text.trim());
      } catch {
        return { question: "How comfortable are you with this topic?", followUpOptions: ["Beginner", "Some experience", "Advanced"] };
      }
    }

    case "update_learning_path": {
      const weakTopics = Object.entries(user.weakSpots || {})
        .sort((a, b) => b[1] - a[1])
        .map(([t]) => t);

      // Reorder path: put weak topics first for remediation
      const reordered = [...(toolInput.currentPath || [])].sort((a, b) => {
        const aWeak = weakTopics.indexOf(a);
        const bWeak = weakTopics.indexOf(b);
        if (aWeak === -1 && bWeak === -1) return 0;
        if (aWeak === -1) return 1;
        if (bWeak === -1) return -1;
        return aWeak - bWeak;
      });

      return {
        updatedPath: reordered,
        changes: weakTopics.length > 0 ? `Prioritized ${weakTopics[0]} for remediation` : "Path maintained",
        remedialTopics: weakTopics.slice(0, 3)
      };
    }

    case "generate_hint": {
      const hintPrompts = [
        `Give a very subtle hint for: "${toolInput.question}". Don't give the answer. 1 sentence.`,
        `Give a moderate hint for: "${toolInput.question}". Point toward the answer. 2 sentences.`,
        `Give a strong hint for: "${toolInput.question}". Almost give the answer. 2-3 sentences.`
      ];
      const level = Math.min(3, Math.max(1, toolInput.hintLevel || 1)) - 1;

      const resp = await anthropic.messages.create({
        model: "claude-sonnet-4-5",
        max_tokens: 200,
        messages: [{ role: "user", content: hintPrompts[level] + `\nContext: ${(toolInput.context || '').substring(0, 300)}` }]
      });

      return { hint: resp.content[0].text.trim(), level: toolInput.hintLevel };
    }

    case "assess_mastery": {
      const answers = toolInput.recentAnswers || [];
      const correct = answers.filter(a => a === true || a?.correct === true).length;
      const rate = answers.length > 0 ? correct / answers.length : 0;
      const avgTime = toolInput.timeSpent / Math.max(1, answers.length);

      let masteryLevel, recommendation;
      if (rate >= 0.9 && avgTime < 30) {
        masteryLevel = "mastered";
        recommendation = "advance";
      } else if (rate >= 0.7) {
        masteryLevel = "proficient";
        recommendation = "review_once_then_advance";
      } else if (rate >= 0.5) {
        masteryLevel = "developing";
        recommendation = "more_practice";
      } else {
        masteryLevel = "struggling";
        recommendation = "full_remediation";
      }

      return { topic: toolInput.topic, masteryLevel, accuracyRate: Math.round(rate * 100), recommendation, avgTimeSeconds: Math.round(avgTime) };
    }

    default:
      return { error: `Unknown tool: ${toolName}` };
  }
}

// ══════════════════════════════════════════════
// CORE AGENTIC LOOP - Multi-step autonomous AI
// ══════════════════════════════════════════════
async function runAgentLoop(systemPrompt, userMessage, userId, maxIterations = 8) {
  const memory = agentMemory.get(userId) || { conversationHistory: [], insights: [] };
  const messages = [{ role: "user", content: userMessage }];

  let iteration = 0;
  let finalResult = null;

  while (iteration < maxIterations) {
    iteration++;
    console.log(`🤖 Agent iteration ${iteration}/${maxIterations}`);

    const response = await anthropic.messages.create({
      model: "claude-sonnet-4-5",
      max_tokens: 4000,
      system: systemPrompt,
      tools: AGENT_TOOLS,
      messages
    });

    // Add assistant response to conversation
    messages.push({ role: "assistant", content: response.content });

    // Check stop condition
    if (response.stop_reason === "end_turn") {
      const textBlock = response.content.find(b => b.type === "text");
      finalResult = textBlock ? textBlock.text : null;
      break;
    }

    // Process tool calls
    if (response.stop_reason === "tool_use") {
      const toolUseBlocks = response.content.filter(b => b.type === "tool_use");
      const toolResults = [];

      for (const toolUse of toolUseBlocks) {
        console.log(`  🔧 Tool called: ${toolUse.name}`);
        let result;
        try {
          result = await executeTool(toolUse.name, toolUse.input, userId);
          console.log(`  ✅ Tool ${toolUse.name} completed`);
        } catch (err) {
          console.error(`  ❌ Tool ${toolUse.name} failed:`, err.message);
          result = { error: err.message };
        }

        toolResults.push({
          type: "tool_result",
          tool_use_id: toolUse.id,
          content: JSON.stringify(result)
        });
      }

      messages.push({ role: "user", content: toolResults });
    }

    if (iteration >= maxIterations) {
      console.warn("⚠️ Agent hit max iterations");
      const lastText = response.content.find(b => b.type === "text");
      finalResult = lastText?.text || "Agent completed processing";
    }
  }

  // Store conversation to memory
  memory.conversationHistory = messages.slice(-20); // Keep last 20
  agentMemory.set(userId, memory);

  return finalResult;
}

