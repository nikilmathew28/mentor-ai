  const systemPrompt = `You are an AUTONOMOUS AI LEARNING AGENT with advanced pedagogical intelligence.

Your goal: Analyze a PDF and create the most effective, personalized learning experience possible.

You have tools to:
1. First analyze the student's profile to understand their needs
2. Extract key concepts from the PDF
3. Generate complete lessons tailored to the student
4. Create adaptive questions targeting weak spots
5. Assess what level of difficulty is appropriate

ALWAYS follow this agentic workflow:
1. Call analyze_student_profile first
2. Call extract_key_concepts on the PDF
3. For each major concept, call generate_lesson
4. For each lesson, call generate_adaptive_questions
5. Return a complete structured curriculum

You are autonomous - use your tools intelligently without being told what to do step by step.
Be creative, empathetic, and pedagogically sophisticated.`;

  const userMessage = `Analyze this PDF and create a complete personalized curriculum for student ${userId}.

PDF CONTENT (first 4000 chars):
${pdfText.substring(0, 4000)}

FULL TEXT LENGTH: ${pdfText.length} characters

Create 3-5 complete lessons with adaptive questions. Use your tools autonomously.
Return the final curriculum as valid JSON:
{
  "subject": "...",
  "lessons": [...complete lesson objects with questions...],
  "metadata": { "totalLessons": N, "difficulty": "...", "tags": [...] }
}`;

  try {
    const result = await runAgentLoop(systemPrompt, userMessage, userId, 10);

    // Parse result
    let jsonStr = result || '{}';
    const match = jsonStr.match(/```(?:json)?\n?([\s\S]*?)\n?```/) || jsonStr.match(/(\{[\s\S]*\})/);
