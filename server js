// AGENTIC HINT GENERATION
// ══════════════════════════════════════════════
async function agentGetHint(userId, question, hintLevel, context) {
  const systemPrompt = `You are a Socratic AI tutor. You give hints that guide students to the answer without giving it away.`;
  const userMessage = `Generate a level ${hintLevel} hint for: "${question}"\nContext: ${(context || '').substring(0, 300)}`;

  try {
    return await runAgentLoop(systemPrompt, userMessage, userId, 3);
  } catch {
    return "Think carefully about the key terms in the question...";
  }
}

