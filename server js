// ── Upload PDF ──────────────────────────────
app.post('/api/upload-pdf', upload.single('pdf'), async (req, res) => {
  console.log('\n' + '═'.repeat(60));
  console.log('📤 AGENTIC PDF UPLOAD');
  console.log('═'.repeat(60));

  try {
    if (!req.file) return res.status(400).json({ success: false, error: 'No PDF uploaded' });
    const { userId } = req.body;
    if (!userId) return res.status(400).json({ success: false, error: 'Missing userId' });

    if (!users.has(userId)) users.set(userId, newUser(userId));
    const user = users.get(userId);
    user.sessionCount++;

    console.log(`👤 User: ${userId} | File: ${req.file.originalname}`);

    const buffer = fs.readFileSync(req.file.path);
    const pdfData = await pdfParse(buffer);
    console.log(`📄 Pages: ${pdfData.numpages} | Text: ${pdfData.text.length} chars`);

    // 🤖 Run agentic lesson generation
    const curriculum = await agentGenerateLessons(pdfData.text, userId);

    pdfStore.set(userId, {
      filename: req.file.originalname,
      pages: pdfData.numpages,
      text: pdfData.text,
      textPreview: pdfData.text.substring(0, 2000),
      lessons: curriculum.lessons || [],
      subject: curriculum.subject || 'Your Subject',
      metadata: curriculum.metadata || {},
      uploadedAt: new Date().toISOString()
    });

    user.totalLessons = curriculum.lessons?.length || 0;
    user.currentLessonIndex = 0;

    fs.unlinkSync(req.file.path);

    // Ask first clarifying question
    const clarification = await agentAskClarification(userId, `Student just uploaded a PDF about "${curriculum.subject}"`);

    res.json({
      success: true,
      message: '✅ PDF analyzed by Agentic AI!',
      subject: curriculum.subject,
      lessonsCreated: curriculum.lessons?.length || 0,
      difficulty: curriculum.metadata?.difficulty || 'adaptive',
      clarifyingQuestion: clarification,
      user: {
        level: user.level, xp: user.xp, companion: user.companion,
        streak: user.streak, accuracy: user.accuracy
      }
    });

  } catch (err) {
    console.error('❌ Upload error:', err);
    if (req.file) try { fs.unlinkSync(req.file.path); } catch {}
    res.status(500).json({ success: false, error: err.message });
  }
});

// ── Get Lesson ──────────────────────────────
app.post('/api/get-lesson', (req, res) => {
  try {
    const { userId } = req.body;
    const user = users.get(userId);
    const data = pdfStore.get(userId);

    if (!data?.lessons?.length) {
      return res.json({ success: false, lesson: null, message: 'No lessons yet. Upload a PDF first.' });
    }

    const idx = user?.currentLessonIndex || 0;
    const lesson = data.lessons[idx];

    if (user) user.lastActive = new Date().toISOString();

    res.json({
      success: true,
      lesson,
      progress: {
        current: idx + 1,
        total: data.lessons.length,
        percentage: Math.round(((idx + 1) / data.lessons.length) * 100),
        completedLessons: user?.completedLessons?.length || 0
      },
      user: user ? {
        level: user.level, xp: user.xp, companion: user.companion,
        streak: user.streak, accuracy: user.accuracy, weakSpots: user.weakSpots
      } : null
    });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// ── Submit Answer (with agentic diagnosis) ──
app.post('/api/submit-answer', async (req, res) => {
  try {
    const { userId, isCorrect, questionId, question, correctAnswer, studentAnswer, topic, timeSpent } = req.body;

    let user = users.get(userId);
    if (!user) { user = newUser(userId); users.set(userId, user); }

    // Update stats
    user.totalQuestions++;
    user.performanceHistory = [...(user.performanceHistory || []), { correct: isCorrect, topic, time: timeSpent }].slice(-20);

    if (isCorrect) {
      user.correctAnswers++;
      user.xp += 10;
      user.streak++;
      if (user.streak > user.highestStreak) user.highestStreak = user.streak;

      // Mark topic progress
      if (topic && user.weakSpots[topic]) {
        user.weakSpots[topic] = Math.max(0, user.weakSpots[topic] - 1);
        if (user.weakSpots[topic] === 0) delete user.weakSpots[topic];
      }
    } else {
      user.streak = 0;
      // Track weak spots
      if (topic) user.weakSpots[topic] = (user.weakSpots[topic] || 0) + 1;
    }

    // Level up
    const xpNeeded = user.level * 50;
    if (user.xp >= xpNeeded) {
      user.level++;
      if (user.level >= 5) user.companion = '🐉';
      else if (user.level >= 3) user.companion = '🐣';
    }

    // Achievements
    const newAchievements = [];
    if (user.streak >= 5 && !user.achievements.includes('🔥 Hot Streak')) {
      user.achievements.push('🔥 Hot Streak'); user.xp += 25; newAchievements.push('🔥 Hot Streak');
    }
    if (user.correctAnswers >= 10 && !user.achievements.includes('🎯 Sharp Shooter')) {
      user.achievements.push('🎯 Sharp Shooter'); user.xp += 30; newAchievements.push('🎯 Sharp Shooter');
    }
    if (user.level >= 3 && !user.achievements.includes('🐣 Evolved!')) {
      user.achievements.push('🐣 Evolved!'); newAchievements.push('🐣 Evolved!');
    }

    user.accuracy = Math.round((user.correctAnswers / user.totalQuestions) * 100);
    user.lastActive = new Date().toISOString();

    let agentDiagnosis = null;
    if (!isCorrect && question && correctAnswer) {
      // 🤖 Agentic misconception diagnosis
      agentDiagnosis = await agentDiagnoseMisconception(userId, question, correctAnswer, studentAnswer || 'unknown', topic || 'general');
    }

    res.json({
      success: true,
      correct: isCorrect,
      agentDiagnosis,
      newAchievements,
      user: {
        level: user.level, xp: user.xp, companion: user.companion,
        streak: user.streak, highestStreak: user.highestStreak,
        accuracy: user.accuracy, totalQuestions: user.totalQuestions,
        weakSpots: user.weakSpots, achievements: user.achievements
      },
      feedback: isCorrect
        ? { message: '✨ Correct! Great work!', xpGained: 10, encouragement: user.streak > 3 ? `${user.streak} in a row! You're on fire! 🔥` : 'Keep it up!' }
        : { message: '🤔 Not quite right.', encouragement: 'Every mistake is data that makes you smarter!' }
    });

  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

