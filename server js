// AGENTIC CLARIFYING QUESTION
// ══════════════════════════════════════════════
async function agentAskClarification(userId, situation) {
  const user = users.get(userId) || newUser(userId);

  const systemPrompt = `You are an intelligent learning companion. Ask ONE concise clarifying question to personalize the student's learning experience.`;
  const userMessage = `Situation: ${situation}\nStudent profile: Level ${user.level}, Accuracy ${user.accuracy}%, Weak spots: ${Object.keys(user.weakSpots || {}).slice(0,3).join(', ')}`;

  try {
    const result = await runAgentLoop(systemPrompt, userMessage, userId, 3);
    return result;
  } catch {
    return "How would you describe your current understanding of this topic?";
  }
}

