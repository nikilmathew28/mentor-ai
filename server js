async function agentDiagnoseMisconception(userId, question, correctAnswer, studentAnswer, topic) {
  const user = users.get(userId);
  const pdfData = pdfStore.get(userId);

  const systemPrompt = `You are an empathetic AI tutor specializing in diagnosing student misconceptions.
When a student gets something wrong, you don't just tell them the answer - you understand WHY they got it wrong
and provide targeted, encouraging remediation. Use your tools to analyze and respond.`;

  const userMessage = `A student just answered incorrectly. Help them understand.

Question: ${question}
Correct Answer: ${correctAnswer}  
Student Answered: ${studentAnswer}
Topic: ${topic}
Student Level: ${user?.level || 1}
Student Accuracy: ${user?.accuracy || 0}%

